# Frontend environment variables (Create a .env file next to package.json)

# Backend URL
REACT_APP_BACKEND_URL=http://localhost:8080

# Firebase (from Firebase Console → Project settings → Web app)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Stripe (Publishable key starts with pk_...)
REACT_APP_STRIPE_PUBLISHABLE_KEY=
# Comma-separated admin e-mails for classroom demo fallback
REACT_APP_ADMIN_EMAILS=lehrerdemir@gmail.com

# Local quick-run mode. true: demo login/payment, false: real Firebase/Stripe.
REACT_APP_DEMO_AUTH=true
REACT_APP_DEMO_PAYMENT=true
